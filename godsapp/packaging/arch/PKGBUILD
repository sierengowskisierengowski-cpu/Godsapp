# Maintainer: Joseph Sierengowski
pkgname=godsapp
pkgver=0.1.0
pkgrel=1
pkgdesc="Professional security auditing & research suite — native GTK4 desktop app"
arch=('any')
url="https://github.com/jsierengowski/godsapp"
license=('GPL3')
depends=(
  'python>=3.12'
  'python-gobject'
  'gtk4'
  'libadwaita'
  'python-sqlalchemy'
  'python-fastapi'
  'python-uvicorn'
  'python-pydantic'
  'python-click'
  'python-rich'
  'python-httpx'
  'python-dnspython'
  'python-psutil'
  'python-platformdirs'
  'python-cryptography'
)
optdepends=(
  'nmap: network scanning'
  'hashcat: password cracking'
  'hydra: network login bruteforcer'
  'sqlmap: SQL injection scanner'
  'nikto: web server scanner'
  'gobuster: directory/file enumeration'
  'ffuf: fast web fuzzer'
  'tcpdump: packet capture'
  'wireshark-cli: protocol analyser'
  'masscan: fast port scanner'
  'subfinder: subdomain discovery'
  'amass: attack surface mapping'
  'wpscan: WordPress scanner'
  'theharvester: OSINT email/host harvester'
  'metasploit: exploitation framework'
)
makedepends=('python-build' 'python-installer' 'python-wheel' 'python-setuptools')
source=("$pkgname-$pkgver.tar.gz::https://github.com/jsierengowski/godsapp/archive/v$pkgver.tar.gz")
sha256sums=('SKIP')

build() {
  cd "$pkgname-$pkgver"
  python -m build --wheel --no-isolation
}

package() {
  cd "$pkgname-$pkgver"
  python -m installer --destdir="$pkgdir" dist/*.whl

  install -Dm644 packaging/com.sierengowski.GodsApp.svg \
    "$pkgdir/usr/share/icons/hicolor/scalable/apps/com.sierengowski.GodsApp.svg"

  install -Dm644 /dev/stdin "$pkgdir/usr/share/applications/com.sierengowski.GodsApp.desktop" <<EOF
[Desktop Entry]
Type=Application
Name=GodsApp
GenericName=Security Research Suite
Comment=Professional security auditing and research suite
Exec=godsapp %U
Icon=com.sierengowski.GodsApp
Categories=Security;Network;System;
Terminal=false
StartupNotify=true
StartupWMClass=com.sierengowski.GodsApp
EOF

  install -Dm644 /dev/stdin "$pkgdir/usr/lib/systemd/user/godsapp-api.service" <<EOF
[Unit]
Description=GodsApp REST API
After=default.target

[Service]
Type=simple
ExecStart=/usr/bin/godsapp-cli api start
Restart=on-failure
RestartSec=3
Environment=PYTHONUNBUFFERED=1

[Install]
WantedBy=default.target
EOF

  install -Dm644 README.md "$pkgdir/usr/share/doc/$pkgname/README.md"
  install -Dm644 LICENSE   "$pkgdir/usr/share/licenses/$pkgname/LICENSE" 2>/dev/null || true
}
